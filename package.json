{
  "name": "disk-agent",
  "version": "0.1.0",
  "description": "OpenClaw/Hermes-style personal AI agent gateway powered by Pi",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "disk-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "disk-agent.config.example.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "gateway": "tsx src/cli.ts gateway",
    "setup": "tsx src/cli.ts setup",
    "test": "tsx --test test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "ai-agent",
    "telegram",
    "openclaw",
    "hermes",
    "pi-coding-agent",
    "pi-supergrok",
    "xai",
    "grok",
    "cron",
    "memory"
  ],
  "license": "MIT",
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.45.1",
    "pi-supergrok": "^0.2.2",
    "typebox": "^1.3.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
